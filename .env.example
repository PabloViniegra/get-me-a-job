# Required in every environment.
# In dev, .env is loaded by Next.js / Bun automatically.
# In Vercel, set these via the dashboard or `vercel env add`.

DATABASE_URL=
ROUTER_API_KEY=
APIFY_API_KEY=
APIFY_WEBHOOK_SECRET=
APIFY_ADMIN_SECRET=

# Actor ID and JSON-encoded input for the LinkedIn Jobs scrape trigger.
# Actor shape is per-actor — for cheap_scraper/linkedin-job-scraper the
# input typically includes keyword, locations, publishedAt, workType, etc.
# Example:
#   APIFY_ACTOR_ID=cheap_scraper/linkedin-job-scraper
#   APIFY_SEARCH_INPUT={"keyword":"Senior Frontend Engineer","locations":["Madrid"],"publishedAt":"24h"}
APIFY_ACTOR_ID=
APIFY_SEARCH_INPUT=

# Optional. Defaults to "meta-llama/llama-3.3-70b-instruct:free".
# Override to a paid model (e.g. anthropic/claude-3-haiku) to avoid free-tier 429s.
OPENROUTER_MODEL=

# Optional. Base64-encoded CV plain text. Required in environments where
# the cv/ directory isn't deployed (Vercel). In dev, leaving this empty
# makes loadCV() read cv/CV_2026.pdf from disk.
# Generate the value with: bun run scripts/extract-cv.ts
CV_TEXT=
