datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model JobOffer {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  jobId          String      @unique
  title          String
  format         String      // e.g., Remote, Hybrid, On-site
  salary         String?
  linkedinUrl    String
  description    String
  descriptionHash String?
  requirements   String[]
  aiAnalysis     AiAnalysis?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

type AiAnalysis {
  whyItFits String
  score     Int
}
